# Dockerfile for contract validation tests
# Usage: docker compose --profile test up contract-tests

FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy contract definitions and tests
COPY contracts/ /app/contracts/

# Install test dependencies using uv
RUN uv sync --project /app/contracts

# Run tests with exit code
CMD ["uv", "run", "--project", "contracts", "pytest", "contracts/test_contracts.py", "-v", "--tb=short"]
