# Dockerfile for contract validation tests
# Usage: docker compose --profile test up contract-tests

FROM python:3.11-slim

WORKDIR /app

# Install uv
RUN pip install --no-cache-dir uv

# Copy contract definitions and tests
COPY src/contracts /app/src/contracts/

# Install test dependencies using uv
RUN uv sync --project /app/src/contracts

# Run tests with exit code
CMD ["uv", "run", "--project", "src/contracts", "pytest", "src/contracts/test_contracts.py", "-v", "--tb=short"]
